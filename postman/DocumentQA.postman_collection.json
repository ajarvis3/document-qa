{
  "info": {
    "_postman_id": "bfa72297-a9f7-4b67-a6ff-74b66074fc36",
    "name": "Document QA API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for uploading a PDF and asking questions against it."
  },
  "item": [
    {
      "name": "Upload Document",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/document-qa/upload",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "document-qa",
            "upload"
          ]
        },
        "description": "Uploads a PDF file and returns a fileUri used by the ask endpoint."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json && json.fileUri) {",
              "    pm.collectionVariables.set('fileUri', json.fileUri);",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Ask Question",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"What is this document about?\",\n  \"fileUri\": \"{{fileUri}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/document-qa/ask",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "document-qa",
            "ask"
          ]
        },
        "description": "Asks a question using the uploaded document fileUri."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has answer field', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('answer');",
              "});"
            ]
          }
        }
      ],
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "fileUri",
      "value": ""
    }
  ]
}

